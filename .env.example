# =============================================================================
# Auth Service — Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env files.
# =============================================================================

# --- Server ---
PORT=1601
NODE_ENV=development
DOMAIN=localhost
APP_URL=http://localhost:1601
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://og@localhost:5432/alternatefutures_auth

# --- JWT ---
# Generate with: openssl rand -base64 32
# IMPORTANT: JWT_SECRET must match service-cloud-api for token verification.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Email (Resend — https://resend.com) ---
# Leave empty for dev — OTP codes are logged to console instead of emailed.
RESEND_API_KEY=

# --- SMS (Twilio — optional) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# --- OAuth Providers (all optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/google
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/github
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/twitter
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/discord

# --- Payments (Stripe) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- AI Proxy API Keys (all optional — for inference routing) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# STABILITY_API_KEY=
# ELEVENLABS_API_KEY=
# FAL_AI_API_KEY=
# WORLDLABS_API_KEY=

# --- Rate Limiting ---
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60000

# --- Redis (optional — for distributed rate limiting in production) ---
# REDIS_URL=redis://localhost:6379

# --- Secrets Management (Infisical — production only) ---
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_SITE_URL=
