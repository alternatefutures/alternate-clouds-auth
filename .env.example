# =============================================================================
# service-auth — Environment Variables
# =============================================================================
# Copy to .env.local for local dev. Production values come from K8s secrets/config.
# For production secret deployment use: admin/cloud/secrets/deploy-secrets.sh
# =============================================================================

# =============================================================================
# Core runtime
# =============================================================================
PORT=1601
NODE_ENV=development
DOMAIN=localhost
APP_URL=http://localhost:1601
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# Whitelist (invite-only access control)
# =============================================================================
# When true (default), only identifiers in auth_whitelist can log in.
# Set to 'false' to open the platform to everyone.
WHITELIST_ENABLED=true

# =============================================================================
# Database
# =============================================================================
# Local dev DB
DATABASE_URL=postgresql://og@localhost:5432/alternatefutures_auth

# =============================================================================
# JWT and internal auth
# =============================================================================
# MUST match service-cloud-api JWT_SECRET
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Shared internal secret used by service-cloud-api -> service-auth calls
AUTH_INTROSPECTION_SECRET=

# service-cloud-api base URL (for cross-service calls like suspend-org)
CLOUD_API_URL=http://localhost:1602

# Optional; defaults to a key derived from JWT_SECRET if unset
TOKEN_ENCRYPTION_KEY=

# OAuth redirect safety list (comma-separated)
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000,http://localhost:1601

# =============================================================================
# Email / SMS / auth UX
# =============================================================================
FROM_EMAIL=auth@alternatefutures.ai
RESEND_API_KEY=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Redis (optional; recommended in production for distributed rate limits)
REDIS_URL=redis://localhost:6379

# AWS/K3s deployments can leave this empty
CLOUDFLARE_ACCOUNT_ID=

# =============================================================================
# OAuth providers (optional)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/github

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/twitter

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/discord

# =============================================================================
# Billing and payments
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Free compute credit (in USD cents) seeded into a new org's wallet on
# signup. Must be a non-negative integer ≤ 1_000_000 (= $10,000); values
# outside that range fall back to the 500 default and log a warning.
# Surfaced read-only via /admin/users `config.signupCreditCents` so the
# admin dashboard never drifts from this value.
SIGNUP_CREDIT_CENTS=500

# =============================================================================
# Discord notifications (optional)
# =============================================================================
# Webhook URL for the #signups channel (or wherever you want new-user pings).
# Separate from DISCORD_FEEDBACK_WEBHOOK_URL (which lives in service-cloud-api
# and routes bug reports / feedback to the support channel). If unset, the
# notifier is a no-op and signups proceed normally.
DISCORD_SIGNUPS_WEBHOOK_URL=

# =============================================================================
# AI provider proxy keys (all optional)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
STABILITY_API_KEY=
ELEVENLABS_API_KEY=
FAL_KEY=
WORLDLABS_API_KEY=
