# =============================================================================
# Alternate Futures Auth Service — Environment Variables
# =============================================================================

# Server Configuration
PORT=1601
NODE_ENV=development
DOMAIN=alternatefutures.ai
APP_URL=http://localhost:1601
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alternatefutures

# =============================================================================
# JWT Secrets (generate strong random strings — e.g. openssl rand -hex 32)
# IMPORTANT: In production, process will crash if these are unset.
# JWT_SECRET must match service-cloud-api's JWT_SECRET.
# =============================================================================
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Token Encryption (for PAT storage)
# Falls back to JWT_SECRET if unset, but a dedicated key is recommended.
# =============================================================================
# TOKEN_ENCRYPTION_KEY=your-encryption-key-here

# =============================================================================
# Redis (recommended for production rate limiting)
# Without this, rate limiting is in-memory only (doesn't scale across instances).
# =============================================================================
# REDIS_URL=redis://localhost:6379

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=

# =============================================================================
# SMS (Twilio)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# OAuth Providers
# =============================================================================

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/google

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/github

# Twitter/X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/twitter

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:1601/auth/oauth/callback/discord

# Apple (currently disabled)
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# =============================================================================
# Payments
# =============================================================================

# Stripe (primary)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stax (optional)
# STAX_API_KEY=
# STAX_MERCHANT_ID=
# STAX_WEBHOOK_SECRET=
# STAX_SANDBOX=true

# Relay (optional)
# RELAY_API_KEY=
# RELAY_WEBHOOK_SECRET=

# =============================================================================
# AI Provider API Keys (for inference proxy — all optional)
# =============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# STABILITY_API_KEY=
# ELEVENLABS_API_KEY=
# FAL_AI_API_KEY=
# WORLDLABS_API_KEY=

# =============================================================================
# Secrets Management (Infisical — production)
# =============================================================================
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=
# INFISICAL_GLOBAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_SITE_URL=

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# =============================================================================
# Optional: Service-to-service auth
# =============================================================================
# AUTH_INTROSPECTION_SECRET=
