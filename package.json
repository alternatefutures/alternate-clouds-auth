{
  "name": "@alternatefutures/auth-service",
  "version": "0.1.0",
  "description": "Alternate Futures Authentication Service - Multi-method authentication system",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio --port 1610",
    "db:seed": "tsx scripts/seed-plans.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "authentication",
    "auth",
    "jwt",
    "oauth",
    "web3",
    "wallet",
    "magic-link",
    "passwordless"
  ],
  "author": "Alternate Futures",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@infisical/sdk": "^2.3.4",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "@prisma/client": "^6.1.0",
    "dotenv": "^17.2.4",
    "ethers": "^6.13.0",
    "hono": "^4.11.7",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "stripe": "^20.3.1",
    "twilio": "^5.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^24.10.1",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "prisma": "^6.1.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.63.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
