// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ACCESS CONTROL
// ============================================

model AuthWhitelist {
  id             String   @id @default(uuid())
  identifier     String   @unique // email, phone, or wallet address (stored lowercase)
  identifierType String   @map("identifier_type") // email | phone | wallet
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("auth_whitelist")
}

// Self-service requests from users who hit the early-access gate.
// Approving a row creates the matching `AuthWhitelist` entry and
// triggers an "you're in" email; declining only flips the status so
// the same email cannot spam the form again. Email is unique to make
// the public submit endpoint trivially idempotent.
enum WhitelistRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model AuthWhitelistRequest {
  id         String                 @id @default(uuid())
  email      String
  identifier String                 @unique
  identifierType String             @default("email") @map("identifier_type")
  name       String
  reason     String                 @db.Text
  status     WhitelistRequestStatus @default(PENDING)
  ipAddress  String?                @map("ip_address")
  userAgent  String?                @map("user_agent")
  reviewedAt DateTime?              @map("reviewed_at")
  reviewedBy String?                @map("reviewed_by") // admin email/id, free-form
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("auth_whitelist_requests")
}

// ============================================
// AUTH CORE MODELS
// ============================================

model AuthUser {
  id            String    @id @default(uuid())
  email         String?   @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  phone         String?   @unique
  phoneVerified Boolean   @default(false) @map("phone_verified")
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  authMethods           AuthMethod[]
  sessions              AuthSession[]
  personalAccessTokens  PersonalAccessToken[]
  billingCustomer       BillingCustomer?
  connectedAccounts     ConnectedAccount[]
  organizationMembers   OrganizationMember[]

  // Usage wallet relations
  usageLedgerEntries    OrganizationUsageLedger[]
  usageLogEntries       OrganizationUsageLog[]
  usageCostsPrivate     OrganizationUsageCostsPrivate[]

  @@map("auth_users")
}

model AuthMethod {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  methodType          String    @map("method_type") // email, sms, wallet, oauth
  provider            String?   // google, github, twitter, discord, etc.
  identifier          String
  oauthAccessToken    String?   @map("oauth_access_token")
  oauthRefreshToken   String?   @map("oauth_refresh_token")
  oauthTokenExpiresAt DateTime? @map("oauth_token_expires_at")
  verified            Boolean   @default(false)
  isPrimary           Boolean   @default(false) @map("is_primary")
  createdAt           DateTime  @default(now()) @map("created_at")
  lastUsedAt          DateTime? @map("last_used_at")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, methodType])
  @@index([userId])
  @@map("auth_methods")
}

model AuthSession {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  refreshToken   String    @unique @map("refresh_token")
  tokenFamily    String    @default(uuid()) @map("token_family")
  tokenVersion   Int       @default(0) @map("token_version")
  userAgent      String?   @map("user_agent")
  ipAddress      String?   @map("ip_address")
  deviceId       String?   @map("device_id")
  expiresAt      DateTime  @map("expires_at")
  revoked        Boolean   @default(false)
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenFamily])
  @@map("auth_sessions")
}

// ============================================
// AUTH AUDIT LOG
// ============================================

enum AuthAuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  TOKEN_REFRESH
  TOKEN_REFRESH_REUSE
  SESSION_REVOKE
  PASSWORD_CHANGE
  MFA_ENABLED
  MFA_DISABLED
  PAT_CREATED
  PAT_DELETED
  ACCOUNT_LOCKED
  RATE_LIMIT_EXCEEDED
  OTP_ISSUED
  OAUTH_START
  OAUTH_FAILURE
  WALLET_NONCE_ISSUED
  WALLET_LINK_FAILURE
  CLI_PAIR_START
  CLI_PAIR_SUCCESS
  CLI_PAIR_FAILURE
  PROFILE_UPDATE
  AUTH_METHOD_LINK
  AUTH_METHOD_UNLINK
  WHITELIST_MUTATE
}

model AuthAuditLog {
  id        String             @id @default(uuid())
  userId    String?            @map("user_id")
  eventType AuthAuditEventType @map("event_type")
  ipAddress String?            @map("ip_address")
  userAgent String?            @map("user_agent")
  metadata  Json               @default("{}") @map("metadata")
  riskScore Int                @default(0) @map("risk_score")
  createdAt DateTime           @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([ipAddress, createdAt])
  @@map("auth_audit_log")
}

model VerificationCode {
  id          String    @id @default(uuid())
  codeType    String    @map("code_type") // email, sms, mfa
  identifier  String
  code        String
  expiresAt   DateTime  @map("expires_at")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  verified    Boolean   @default(false)
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  ipAddress   String?   @map("ip_address")

  @@index([identifier, codeType])
  @@map("auth_verification_codes")
}

model SIWEChallenge {
  id         String    @id @default(uuid())
  address    String
  message    String
  nonce      String    @unique
  expiresAt  DateTime  @map("expires_at")
  verified   Boolean   @default(false)
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  ipAddress  String?   @map("ip_address")

  @@index([address])
  @@map("auth_siwe_challenges")
}

model PersonalAccessToken {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  organizationId String?   @map("organization_id")
  name           String
  token          String    @unique
  expiresAt      DateTime? @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user         AuthUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([organizationId])
  @@map("auth_personal_access_tokens")
}

// ============================================
// ORGANIZATION MODELS
// ============================================

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members              OrganizationMember[]
  billing              OrganizationBilling?
  personalAccessTokens PersonalAccessToken[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         AuthUser     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationBilling {
  id               String   @id @default(uuid())
  organizationId   String   @unique @map("organization_id")
  stripeCustomerId String?  @unique @map("stripe_customer_id")

  // Trial tracking
  trialStartedAt   DateTime? @map("trial_started_at")
  trialEndsAt      DateTime? @map("trial_ends_at")
  trialConverted   Boolean   @default(false) @map("trial_converted")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions   Subscription[]
  invoices        Invoice[]
  usageRecords    UsageRecord[]
  usageAggregates UsageAggregate[]

  // Usage wallet relations
  usageBalance      OrganizationUsageBalance?
  usageLedger       OrganizationUsageLedger[]
  usageLog          OrganizationUsageLog[]
  usageCostsPrivate OrganizationUsageCostsPrivate[]

  @@index([stripeCustomerId])
  @@map("organization_billing")
}

// ============================================
// BILLING MODELS
// ============================================

model BillingCustomer {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  email            String?
  name             String?
  stripeCustomerId String?  @unique @map("stripe_customer_id")
  staxCustomerId   String?  @unique @map("stax_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user            AuthUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethods  PaymentMethod[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  payments        Payment[]
  usageRecords    UsageRecord[]
  usageAggregates UsageAggregate[]

  @@index([stripeCustomerId])
  @@index([staxCustomerId])
  @@map("auth_billing_customers")
}

model PaymentMethod {
  id                    String   @id @default(uuid())
  customerId            String   @map("customer_id")
  type                  String   // CARD, CRYPTO
  provider              String   // stripe, stax, relay
  cardBrand             String?  @map("card_brand")
  cardLast4             String?  @map("card_last4")
  cardExpMonth          Int?     @map("card_exp_month")
  cardExpYear           Int?     @map("card_exp_year")
  stripePaymentMethodId String?  @unique @map("stripe_payment_method_id")
  staxPaymentMethodId   String?  @unique @map("stax_payment_method_id")
  walletAddress         String?  @map("wallet_address")
  blockchain            String?
  isDefault             Boolean  @default(false) @map("is_default")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  customer BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([customerId])
  @@map("auth_payment_methods")
}

model SubscriptionPlan {
  id               String   @id @default(uuid())
  name             String   @unique // MONTHLY, YEARLY
  basePricePerSeat Int      @map("base_price_per_seat") // in cents (per-month equivalent)
  usageMarkup      Float    @default(0) @map("usage_markup") // markup as decimal, e.g. 0.25 = 25%
  billingInterval  String   @default("MONTHLY") @map("billing_interval") // MONTHLY | YEARLY
  isActive         Boolean  @default(true) @map("is_active")
  features         String?  // JSON array
  stripePriceId    String?  @map("stripe_price_id")

  // Included usage per org/month
  includedStorageGb      Int   @default(0) @map("included_storage_gb")
  includedBandwidthGb    Int   @default(0) @map("included_bandwidth_gb")
  includedInvocations    Int   @default(0) @map("included_invocations")
  includedComputeSeconds Int   @default(0) @map("included_compute_seconds")

  // Trial configuration
  trialDays           Int      @default(0) @map("trial_days")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("auth_subscription_plans")
}

model Subscription {
  id                   String    @id @default(uuid())
  customerId           String    @map("customer_id")
  orgBillingId         String?   @map("org_billing_id")
  planId               String    @map("plan_id")
  status               String    // ACTIVE, TRIALING, TRIAL_EXPIRED, SUSPENDED, CANCELED, PAST_DUE, UNPAID
  seats                Int       @default(1)
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime  @map("current_period_start")
  currentPeriodEnd     DateTime  @map("current_period_end")
  cancelAt             DateTime? @map("cancel_at")
  canceledAt           DateTime? @map("canceled_at")
  trialEnd             DateTime? @map("trial_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  customer   BillingCustomer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orgBilling OrganizationBilling? @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan     @relation(fields: [planId], references: [id])
  invoices   Invoice[]
  usageRecords    UsageRecord[]
  usageAggregates UsageAggregate[]

  @@index([customerId])
  @@index([orgBillingId])
  @@index([status])
  @@map("auth_subscriptions")
}

model Invoice {
  id               String    @id @default(uuid())
  customerId       String    @map("customer_id")
  orgBillingId     String?   @map("org_billing_id")
  subscriptionId   String?   @map("subscription_id")
  invoiceNumber    String    @unique @map("invoice_number")
  status           String    // DRAFT, OPEN, PAID, VOID, UNCOLLECTIBLE
  subtotal         Int       // in cents
  tax              Int       @default(0)
  total            Int
  amountPaid       Int       @default(0) @map("amount_paid")
  amountDue        Int       @map("amount_due")
  currency         String    @default("usd")
  periodStart      DateTime? @map("period_start")
  periodEnd        DateTime? @map("period_end")
  dueDate          DateTime? @map("due_date")
  paidAt           DateTime? @map("paid_at")
  pdfUrl           String?   @map("pdf_url")
  stripeInvoiceId  String?   @unique @map("stripe_invoice_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  customer     BillingCustomer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orgBilling   OrganizationBilling? @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  subscription Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  lineItems    InvoiceLineItem[]
  payments     Payment[]

  @@index([customerId])
  @@index([orgBillingId])
  @@index([status])
  @@map("auth_invoices")
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String   @map("invoice_id")
  description String
  quantity    Float
  unitPrice   Int      @map("unit_price") // in cents
  amount      Int      // in cents
  createdAt   DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("auth_invoice_line_items")
}

model Payment {
  id                    String    @id @default(uuid())
  customerId            String    @map("customer_id")
  invoiceId             String?   @map("invoice_id")
  paymentMethodId       String?   @map("payment_method_id")
  amount                Int       // in cents
  currency              String    @default("usd")
  status                String    // PENDING, SUCCEEDED, FAILED, REFUNDED
  provider              String    // stripe, stax, relay
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id")
  staxTransactionId     String?   @unique @map("stax_transaction_id")
  txHash                String?   @unique @map("tx_hash")
  blockchain            String?
  fromAddress           String?   @map("from_address")
  toAddress             String?   @map("to_address")
  /// Server-chosen stablecoin symbol for crypto top-ups. The Relay
  /// webhook's claimed token must match this value before we credit.
  tokenSymbol           String?   @map("token_symbol")
  /// Canonical ERC-20 contract address resolved at intent creation
  /// from the (chainId, tokenSymbol) allowlist. Never trusted from
  /// webhook input.
  tokenAddress          String?   @map("token_address")
  /// Organization wallet being topped up. Authoritative – the webhook
  /// handler ignores any orgBillingId echoed back in the provider
  /// metadata.
  orgBillingId          String?   @map("org_billing_id")
  failureReason         String?   @map("failure_reason")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  customer      BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice       Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  transfers     Transfer[]
  platformFees  PlatformFee[]

  @@index([customerId])
  @@index([invoiceId])
  @@index([orgBillingId])
  @@map("auth_payments")
}

model UsageRecord {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  orgBillingId   String?  @map("org_billing_id")
  subscriptionId String?  @map("subscription_id")
  metricType     String   @map("metric_type") // storage, bandwidth, compute, requests
  quantity       Float
  unitPrice      Int      @map("unit_price") // in cents
  amount         Int      // in cents
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  recordedAt     DateTime @map("recorded_at")
  createdAt      DateTime @default(now()) @map("created_at")

  customer     BillingCustomer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orgBilling   OrganizationBilling? @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  subscription Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([customerId, periodStart])
  @@index([orgBillingId, periodStart])
  @@index([metricType])
  @@map("auth_usage_records")
}

model UsageAggregate {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  orgBillingId   String?  @map("org_billing_id")
  subscriptionId String?  @map("subscription_id")
  metricType     String   @map("metric_type") // storage, bandwidth, compute, requests
  totalQuantity  Float    @default(0) @map("total_quantity")
  totalAmount    Int      @default(0) @map("total_amount") // in cents
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer     BillingCustomer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orgBilling   OrganizationBilling? @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  subscription Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([customerId, metricType, periodStart])
  @@unique([orgBillingId, metricType, periodStart])
  @@map("auth_usage_aggregates")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  provider    String    // stripe, stax, relay
  eventType   String    @map("event_type")
  eventId     String    @map("event_id")
  payload     String    // JSON
  processed   Boolean   @default(false)
  processedAt DateTime? @map("processed_at")
  error       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@index([processed])
  @@map("auth_webhook_events")
}

// ============================================
// CONNECT / MARKETPLACE MODELS
// ============================================

model ConnectedAccount {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  provider          String   // stripe, stax
  accountType       String   @default("express") @map("account_type") // standard, express, custom
  stripeAccountId   String?  @unique @map("stripe_account_id")
  staxSubMerchantId String?  @unique @map("stax_sub_merchant_id")
  email             String?
  businessName      String?  @map("business_name")
  country           String?
  chargesEnabled    Boolean  @default(false) @map("charges_enabled")
  payoutsEnabled    Boolean  @default(false) @map("payouts_enabled")
  detailsSubmitted  Boolean  @default(false) @map("details_submitted")
  metadata          String?  // JSON
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         AuthUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transfers    Transfer[]
  platformFees PlatformFee[]

  @@index([userId])
  @@index([provider])
  @@map("auth_connected_accounts")
}

model Transfer {
  id                 String   @id @default(uuid())
  connectedAccountId String   @map("connected_account_id")
  paymentId          String?  @map("payment_id")
  amount             Int
  currency           String   @default("usd")
  status             String   // pending, paid, failed, canceled
  provider           String   // stripe, stax
  stripeTransferId   String?  @unique @map("stripe_transfer_id")
  staxSplitId        String?  @unique @map("stax_split_id")
  description        String?
  metadata           String?  // JSON
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  payment          Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([connectedAccountId])
  @@index([paymentId])
  @@index([status])
  @@map("auth_transfers")
}

model PlatformFee {
  id                 String   @id @default(uuid())
  connectedAccountId String   @map("connected_account_id")
  paymentId          String   @map("payment_id")
  amount             Int
  currency           String   @default("usd")
  stripeFeeId        String?  @unique @map("stripe_fee_id")
  createdAt          DateTime @default(now()) @map("created_at")

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  payment          Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([connectedAccountId])
  @@index([paymentId])
  @@map("auth_platform_fees")
}

// ============================================
// USAGE WALLET MODELS (USD cents)
// ============================================

enum UsageLedgerDirection {
  CREDIT
  DEBIT
}

model OrganizationUsageBalance {
  id           String   @id @default(uuid())
  orgBillingId String   @unique @map("org_billing_id")
  balanceCents Int      @default(0) @map("balance_cents") // USD cents (e.g., 2500 = $25.00)
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  orgBilling OrganizationBilling @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)

  @@index([orgBillingId])
  @@map("organization_usage_balance")
}

model OrganizationUsageLedger {
  id             String               @id @default(uuid())
  orgBillingId   String               @map("org_billing_id")
  actorUserId    String?              @map("actor_user_id") // who initiated (optional)
  direction      UsageLedgerDirection
  amountCents    Int                  @map("amount_cents") // USD cents (positive integer)
  reason         String               @map("reason") // topup, ai_inference, compute, storage, bandwidth, etc.
  idempotencyKey String               @unique @map("idempotency_key")
  metadata       Json                 @default("{}") @map("metadata")
  createdAt      DateTime             @default(now()) @map("created_at")

  orgBilling OrganizationBilling @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  actorUser  AuthUser?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgBillingId, createdAt])
  @@index([actorUserId])
  @@index([reason])
  @@map("organization_usage_ledger")
}

model OrganizationUsageLog {
  id           String   @id @default(uuid())
  orgBillingId String   @map("org_billing_id")
  userId       String?  @map("user_id") // nullable for system-initiated debits (billing scheduler)

  serviceType  String   @map("service_type") // ai_inference, compute, storage, bandwidth, etc.
  provider     String   @map("provider") // openai, anthropic, aws, gcp, internal, etc.
  resource     String   @map("resource") // e.g. "chat/completions", "gpu-h100", "s3-storage"
  model        String?  @map("model") // for AI: gpt-4o, claude-3, etc.

  usdCostRaw   Float    @map("usd_cost_raw") // raw provider/compute cost in USD
  marginRate   Float    @map("margin_rate") // applied margin (e.g., 0.5 = 50%)
  usdCharged   Float    @map("usd_charged") // final amount charged = usdCostRaw / (1 - marginRate)

  requestId    String?  @map("request_id") // stable request id if available
  metadata     Json     @default("{}") @map("metadata")

  createdAt    DateTime @default(now()) @map("created_at")

  orgBilling OrganizationBilling @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  user       AuthUser?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgBillingId, createdAt])
  @@index([userId, createdAt])
  @@index([serviceType])
  @@index([provider])
  @@map("organization_usage_log")
}

model OrganizationUsageCostsPrivate {
  id            String   @id @default(uuid())
  orgBillingId  String   @map("org_billing_id")
  userId        String?  @map("user_id") // nullable for system-initiated debits

  serviceType   String   @map("service_type")
  provider      String   @map("provider")
  resource      String   @map("resource")
  model         String?  @map("model")

  usdCostRaw    Float    @map("usd_cost_raw") // what we pay the provider
  usdCharged    Float    @map("usd_charged") // what user pays (with margin)
  marginRate    Float    @map("margin_rate")
  marginUsd     Float    @map("margin_usd") // usdCharged - usdCostRaw (our profit)

  metadata      Json     @default("{}") @map("metadata")
  createdAt     DateTime @default(now()) @map("created_at")

  orgBilling OrganizationBilling @relation(fields: [orgBillingId], references: [id], onDelete: Cascade)
  user       AuthUser?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgBillingId, createdAt])
  @@map("organization_usage_costs_private")
}

// ============================================
// AUDIT LOG (Phase 44)
// ============================================
// Identity + billing half of the platform audit log. An identical model
// lives in service-cloud-api for deployment / health / provider events.
// Schemas are kept in lockstep on purpose — the D3 export cron unifies
// both halves into one JSONL stream for forensics / audits of the first
// 100 users. Append-only. Never mutate existing rows.
//
// Privacy contract enforced by the audit() writer, not here:
//   - payload never contains raw secrets, JWT contents, plaintext passwords,
//     payment-card numbers, or OAuth tokens.
//   - contact info (email, phone) is hashed when it would identify a user
//     who has not yet associated with an org.
model AuditEvent {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now()) @map("timestamp")

  traceId      String   @map("trace_id")

  source       String
  category     String
  action       String
  status       String

  userId       String?  @map("user_id")
  orgId        String?  @map("org_id")
  projectId    String?  @map("project_id")
  serviceId    String?  @map("service_id")
  deploymentId String?  @map("deployment_id")

  durationMs   Int?     @map("duration_ms")
  payload      Json

  errorCode    String?  @map("error_code")
  errorMessage String?  @map("error_message")

  @@index([userId, timestamp])
  @@index([orgId, timestamp])
  @@index([projectId, timestamp])
  @@index([serviceId, timestamp])
  @@index([category, timestamp])
  @@index([action, timestamp])
  @@index([traceId])
  @@index([status, timestamp])
  @@map("audit_events")
}
